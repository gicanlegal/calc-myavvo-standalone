	function uTU(){
	var ta=document.querySelector('input[name="tA"]:checked').value;
	document.getElementById('cS').style.display=ta==='p'?'block':'none';
	document.getElementById('cN').style.display=ta==='n'?'block':'none';
	document.getElementById('tR').style.display='none';
	}

	function cT(){
	var tp=document.querySelector('input[name="tP"]:checked').value;
	var ci=parseFloat(document.querySelector('input[name="tI"]:checked').value);
	var ta=document.querySelector('input[name="tA"]:checked').value;
	var ex='',tf=0;
	if(ta==='n'){
	tf=parseFloat(document.getElementById('tN').value);
	var sel=document.getElementById('tN');
	ex='<strong>Identificarea tipului de cerere:</strong><br><ul>';
	ex+='<li>Tip cerere: '+sel.options[sel.selectedIndex].text+'</li>';
	ex+='<li>Taxa fixă: <strong>'+fM(tf)+' lei</strong></li></ul>';
	}else{
	var sm=parseFloat(document.getElementById('tS').value);
	if(!sm||sm<=0){showErr('Introduceți valoarea acțiunii!','tS');return}
	var mn=tp==='f'?150:250;
	var tpN=tp==='f'?'fizice':'juridice';
	ex='<strong>Identificarea valorii acțiunii:</strong><br><ul>';
	ex+='<li>Valoarea acțiunii este de '+fM(sm)+' lei.</li></ul>';
	ex+='<strong>Determinarea pragului de calcul:</strong><br><ul>';
	if(sm<=5000){
	ex+='<li>Conform Legii taxei de stat Nr. 213 din 31.07.2023, pct. 1.1.1:<br>pentru o valoare a acțiunii mai mică sau egală cu 5000 lei, taxa de stat este <strong>5%</strong> din valoarea acțiunii, dar nu mai puțin de '+mn+' lei pentru persoanele '+tpN+'.</li></ul>';
	tf=sm*0.05;
	ex+='<strong>Calculul taxei:</strong><br><ul>';
	ex+='<li>'+fM(sm)+' lei x 5% = <strong>'+fM(tf)+' lei</strong></li></ul>';
	}else if(sm<=50000){
	ex+='<li>Conform Legii taxei de stat Nr. 213 din 31.07.2023, pct. 1.1.2:<br>pentru o valoare a acțiunii de 5001 - 50000 lei, taxa de stat este <strong>250 lei + 4%</strong> din valoarea acțiunii care depășește 5001 lei.</li></ul>';
	var dif=sm-5001;
	tf=250+dif*0.04;
	ex+='<strong>Calculul diferenței:</strong><br><ul>';
	ex+='<li>Determinăm cât din valoarea acțiunii depășește 5001 lei:<br>';
	ex+=fM(sm)+' lei - 5 001 lei = <strong>'+fM(dif)+' lei</strong></li></ul>';
	ex+='<strong>Calculul procentului de 4%:</strong><br><ul>';
	ex+='<li>Calculăm 4% din această diferență:<br>';
	ex+='4% x '+fM(dif)+' lei = <strong>'+fM(dif*0.04)+' lei</strong></li></ul>';
	ex+='<strong>Adăugarea taxei de bază:</strong><br><ul>';
	ex+='<li>Adăugăm taxa de bază de 250 lei:<br>';
	ex+='250 lei + '+fM(dif*0.04)+' lei = <strong>'+fM(tf)+' lei</strong></li></ul>';
	}else if(sm<=1500000){
	ex+='<li>Conform Legii taxei de stat Nr. 213 din 31.07.2023, pct. 1.1.3:<br>pentru o valoare a acțiunii de 50001 - 1500000 lei, taxa de stat este <strong>2 050 lei + 3%</strong> din valoarea acțiunii care depășește 50001 lei.</li></ul>';
	var dif=sm-50001;
	tf=2050+dif*0.03;
	ex+='<strong>Calculul diferenței:</strong><br><ul>';
	ex+='<li>Determinăm cât din valoarea acțiunii depășește 50001 lei:<br>';
	ex+=fM(sm)+' lei - 50 001 lei = <strong>'+fM(dif)+' lei</strong></li></ul>';
	ex+='<strong>Calculul procentului de 3%:</strong><br><ul>';
	ex+='<li>Calculăm 3% din această diferență:<br>';
	ex+='3% x '+fM(dif)+' lei = <strong>'+fM(dif*0.03)+' lei</strong></li></ul>';
	ex+='<strong>Adăugarea taxei de bază:</strong><br><ul>';
	ex+='<li>Adăugăm taxa de bază de 2 050 lei:<br>';
	ex+='2 050 lei + '+fM(dif*0.03)+' lei = <strong>'+fM(tf)+' lei</strong></li></ul>';
	}else if(sm<=5000000){
	ex+='<li>Conform Legii taxei de stat Nr. 213 din 31.07.2023, pct. 1.1.4:<br>pentru o valoare a acțiunii de 1500001 - 5000000 lei, taxa de stat este <strong>45 550 lei + 2%</strong> din valoarea acțiunii care depășește 1500001 lei.</li></ul>';
	var dif=sm-1500001;
	tf=45550+dif*0.02;
	ex+='<strong>Calculul diferenței:</strong><br><ul>';
	ex+='<li>Determinăm cât din valoarea acțiunii depășește 1 500 001 lei:<br>';
	ex+=fM(sm)+' lei - 1 500 001 lei = <strong>'+fM(dif)+' lei</strong></li></ul>';
	ex+='<strong>Calculul procentului de 2%:</strong><br><ul>';
	ex+='<li>Calculăm 2% din această diferență:<br>';
	ex+='2% x '+fM(dif)+' lei = <strong>'+fM(dif*0.02)+' lei</strong></li></ul>';
	ex+='<strong>Adăugarea taxei de bază:</strong><br><ul>';
	ex+='<li>Adăugăm taxa de bază de 45 550 lei:<br>';
	ex+='45 550 lei + '+fM(dif*0.02)+' lei = <strong>'+fM(tf)+' lei</strong></li></ul>';
	}else if(sm<=10000000){
	ex+='<li>Conform Legii taxei de stat Nr. 213 din 31.07.2023, pct. 1.1.5:<br>pentru o valoare a acțiunii de 5000001 - 10000000 lei, taxa de stat este <strong>115 550 lei + 1%</strong> din valoarea acțiunii care depășește 5000001 lei.</li></ul>';
	var dif=sm-5000001;
	tf=115550+dif*0.01;
	ex+='<strong>Calculul diferenței:</strong><br><ul>';
	ex+='<li>Determinăm cât din valoarea acțiunii depășește 5 000 001 lei:<br>';
	ex+=fM(sm)+' lei - 5 000 001 lei = <strong>'+fM(dif)+' lei</strong></li></ul>';
	ex+='<strong>Calculul procentului de 1%:</strong><br><ul>';
	ex+='<li>Calculăm 1% din această diferență:<br>';
	ex+='1% x '+fM(dif)+' lei = <strong>'+fM(dif*0.01)+' lei</strong></li></ul>';
	ex+='<strong>Adăugarea taxei de bază:</strong><br><ul>';
	ex+='<li>Adăugăm taxa de bază de 115 550 lei:<br>';
	ex+='115 550 lei + '+fM(dif*0.01)+' lei = <strong>'+fM(tf)+' lei</strong></li></ul>';
	}else{
	ex+='<li>Conform Legii taxei de stat Nr. 213 din 31.07.2023, pct. 1.1.6:<br>pentru o valoare a acțiunii egală sau mai mare de 10000001 lei, taxa de stat este <strong>165 550 lei + 0,5%</strong> din valoarea acțiunii care depășește 10000001 lei.</li></ul>';
	var dif=sm-10000001;
	tf=165550+dif*0.005;
	ex+='<strong>Calculul diferenței:</strong><br><ul>';
	ex+='<li>Determinăm cât din valoarea acțiunii depășește 10 000 001 lei:<br>';
	ex+=fM(sm)+' lei - 10 000 001 lei = <strong>'+fM(dif)+' lei</strong></li></ul>';
	ex+='<strong>Calculul procentului de 0,5%:</strong><br><ul>';
	ex+='<li>Calculăm 0,5% din această diferență:<br>';
	ex+='0,5% x '+fM(dif)+' lei = <strong>'+fM(dif*0.005)+' lei</strong></li></ul>';
	ex+='<strong>Adăugarea taxei de bază:</strong><br><ul>';
	ex+='<li>Adăugăm taxa de bază de 165 550 lei:<br>';
	ex+='165 550 lei + '+fM(dif*0.005)+' lei = <strong>'+fM(tf)+' lei</strong></li></ul>';
	}
	if(tf<mn){
	ex+='<strong>⚠️ Verificarea minimului legal:</strong><br><ul>';
	ex+='<li>Taxa calculată ('+fM(tf)+' lei) este sub minimul legal de <strong>'+mn+' lei</strong> pentru persoane '+tpN+'.</li>';
	ex+='<li>Se aplică taxa minimă: <strong>'+mn+' lei</strong></li></ul>';
	tf=mn;
	}
	}
	var fin=Math.round(tf*ci*100)/100;
	var ni=ci===1?'Fond (prima instanță)':ci===0.85?'Apel (85% din taxa fond)':ci===0.7?'Recurs (70% din taxa fond)':'Revizuire (55% din taxa fond)';
	if(ci!==1){
	ex+='<strong>Recalculare pentru instanță:</strong><br><ul>';
	ex+='<li>Instanța: <strong>'+ni+'</strong></li>';
	ex+='<li>Taxa fond: '+fM(tf)+' lei x '+Math.round(ci*100)+'% = <strong>'+fM(fin)+' lei</strong></li></ul>';
	}
	ex+='<br><strong>Taxa de stat finală: '+fM(fin)+' MDL</strong>';
	document.getElementById('tTo').textContent=fM(fin)+' MDL';
	document.getElementById('tIn').textContent=ni;
	document.getElementById('tEx').innerHTML=ex;
	document.getElementById('tR').style.display='block';
	}

	function sM(m){
	zm=m;
	document.getElementById('mDD').classList.toggle('active',m==='dd');
	document.getElementById('mDZ').classList.toggle('active',m==='dz');
	document.getElementById('eT').textContent=m==='dd'?'Data sfârșit':'Zile de adăugat';
	document.getElementById('eDD').style.display=m==='dd'?'block':'none';
	document.getElementById('eZD').style.display=m==='dz'?'block':'none';
	document.getElementById('zR').style.display='none';
	}

	function cZ(){
	var az=new Date();az.setHours(0,0,0,0);
	var st=document.querySelector('input[name="sT"]:checked').value;
	var d1;
	if(st==='a')d1=new Date(az);
	else{var v=document.getElementById('zS').value;if(!v){showErr('Selectați data de început!','zS');return}d1=pD(v)}
	var d2;
	if(zm==='dd'){
	var en=document.querySelector('input[name="eT2"]:checked').value;
	if(en==='a')d2=new Date(az);
	else{var v2=document.getElementById('zE').value;if(!v2){showErr('Selectați data de sfârșit!','zE');return}d2=pD(v2)}
	}else{
	var nrAni=parseInt(document.getElementById('zAni').value)||0;
	var nrLuni=parseInt(document.getElementById('zLuni').value)||0;
	var nrZile=parseInt(document.getElementById('zN').value)||0;
	if(nrAni===0&&nrLuni===0&&nrZile===0){showErr('Introduceți cel puțin o perioadă!','zN');return}
	d2=new Date(d1);
	d2.setFullYear(d2.getFullYear()+nrAni);
	d2.setMonth(d2.getMonth()+nrLuni);
	if(nrZile>0)d2=aDD(d2,nrZile);
	}
	if(d2<d1){var tmp=d1;d1=d2;d2=tmp}
	var zB=dD(d1,d2);
	var inclP=document.getElementById('iP').checked;
	var inclU=document.getElementById('iU').checked;
	var zile=zB;
	if(inclP)zile+=1;
	if(!inclU)zile-=1;
	if(zile<0)zile=0;
	var lucr=0;
	var sC=inclP?new Date(d1):aDD(d1,1);
	var eC=inclU?new Date(d2):aDD(d2,-1);
	if(eC>=sC){var cur=new Date(sC);
	while(cur<=eC){var dow=cur.getDay();if(dow!==0&&dow!==6)lucr++;cur=aDD(cur,1);}}
	var ani=Math.floor(zile/365);
	var rest=zile%365;
	var luni=Math.floor(rest/30);
	rest=rest%30;
	var sapt=Math.floor(rest/7);
	var zRest=rest%7;
	document.getElementById('zTo').textContent=zile+' zile';
	document.getElementById('zLu').textContent=lucr+' zile lucrătoare';
	document.getElementById('zPe').textContent=fR(d1)+' - '+fR(d2);
	document.getElementById('zA').textContent=ani;
	document.getElementById('zL').textContent=luni;
	document.getElementById('zSa').textContent=sapt;
	document.getElementById('zRe').textContent=zRest;
	document.getElementById('dRz').innerHTML=zm==='dz'?'<strong>Data rezultat:</strong> '+fR(d2):'';
	document.getElementById('zR').style.display='block';
	}

	function toggleTheme(){
	var html=document.documentElement;
	var isDark=html.getAttribute('data-theme')==='dark';
	if(isDark){
	html.removeAttribute('data-theme');
	document.getElementById('themeIcon').textContent='☾';
	localStorage.setItem('theme','light');
	}else{
	html.setAttribute('data-theme','dark');
	document.getElementById('themeIcon').textContent='☀';
	localStorage.setItem('theme','dark');
	}}

	// Init: aplica tema salvata
	document.addEventListener('DOMContentLoaded',function(){
	  if(localStorage.getItem('theme')==='dark'){
	    document.documentElement.setAttribute('data-theme','dark');
	    var icon=document.getElementById('themeIcon');
	    if(icon)icon.textContent='☀';
	  }
	});

	// ── UX: Select-all on focus pentru input[type="number"] ──
	document.addEventListener('focus',function(e){
	  if(e.target.matches('input[type="number"]')){e.target.select();}
	},true);

	// ── UX: Mască dată zz/ll/aaaa ─────────────────────────
	function maskDate(input){
	  input.addEventListener('input',function(){
	    var cp=this.selectionStart;
	    var dbc=this.value.substring(0,cp).replace(/\D/g,'').length;
	    var v=this.value.replace(/\D/g,'');
	    if(v.length>8)v=v.substring(0,8);
	    if(v.length>=5){this.value=v.substring(0,2)+'/'+v.substring(2,4)+'/'+v.substring(4);}
	    else if(v.length>=3){this.value=v.substring(0,2)+'/'+v.substring(2);}
	    else{this.value=v;}
	    var np=0,dc=0;
	    while(np<this.value.length&&dc<dbc){if(/\d/.test(this.value[np]))dc++;np++;}
	    this.setSelectionRange(np,np);
	  });
	  input.addEventListener('keydown',function(e){
	    if(e.key==='Backspace'||e.key==='Delete'){
	      var digits=this.value.replace(/\D/g,'');
	      if(digits.length<=1){e.preventDefault();this.value='';return;}
	      if(this.selectionStart===0&&this.selectionEnd===this.value.length){e.preventDefault();this.value='';}
	    }
	  });
	}

	// ── UX: Buton ✕ pe câmpurile date ──────────────────────
	function wrapDateInput(input){
	  if(!input||!input.parentNode)return;
	  if(input.closest('.date-wrap'))return;
	  maskDate(input);
	  var wrap=document.createElement('span');
	  wrap.className='date-wrap';
	  input.parentNode.insertBefore(wrap,input);
	  wrap.appendChild(input);
	  var btn=document.createElement('button');
	  btn.type='button';btn.className='date-clear';
	  btn.title='Șterge data';btn.textContent='✕';
	  btn.addEventListener('click',function(e){
	    e.preventDefault();input.value='';input.focus();
	  });
	  wrap.appendChild(btn);
	}

	// ── UX: Buton "Curăță" pe fiecare .ib ──────────────────
	function clearItem(btn){
	  var ib=btn.closest('.ib');if(!ib)return;
	  ib.querySelectorAll('.date-input').forEach(function(inp){inp.value='';});
	  ib.querySelectorAll('input[type="number"]').forEach(function(inp){inp.value='';});
	}
	function addClearBtn(ib){
	  if(!ib||ib.querySelector('.bclear'))return;
	  var del=ib.querySelector('.br');if(!del)return;
	  var btn=document.createElement('button');
	  btn.type='button';btn.className='bclear';btn.textContent='Curăță';
	  btn.onclick=function(){clearItem(this);};
	  del.parentNode.insertBefore(btn,del);
	}

	// ── Init + MutationObserver pentru itemi dinamici ───────
	document.addEventListener('DOMContentLoaded',function(){
	  document.querySelectorAll('.date-input').forEach(wrapDateInput);
	  document.querySelectorAll('.ib').forEach(addClearBtn);
	  var observer=new MutationObserver(function(mutations){
	    mutations.forEach(function(m){
	      m.addedNodes.forEach(function(node){
	        if(node.nodeType!==1)return;
	        if(node.classList&&node.classList.contains('ib')){
	          node.querySelectorAll('.date-input').forEach(wrapDateInput);
	          addClearBtn(node);
	        }
	      });
	    });
	  });
	  ['fL','pL','pfL','ppL'].forEach(function(id){
	    var el=document.getElementById(id);
	    if(el)observer.observe(el,{childList:true});
	  });
	});
	</script>

	<!-- Modal eroare validare -->
	<div id="errModal" class="err-overlay" onclick="if(event.target===this)closeErr()">
	  <div class="err-box">
	    <div class="err-icon">⚠️</div>
	    <div class="err-msg" id="errMsg"></div>
	    <button class="err-ok" onclick="closeErr()">Am înțeles</button>
	  </div>
	</div>