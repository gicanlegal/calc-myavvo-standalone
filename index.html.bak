	];
	function getCurrency(){return selectedCurrency;}
	function setCurrency(val){
	  var c=CURRENCIES.find(function(x){return x.code===val;})||{code:val,name:val};
	  selectedCurrency=val;
	  ['dob','pen'].forEach(function(t){
	    var ce=document.getElementById('curCode-'+t),ne=document.getElementById('curNm-'+t);
	    if(ce)ce.textContent=c.code;if(ne)ne.textContent=c.name;
	  });
	}
	function buildCurDD(tab){
	  var dd=document.getElementById('curDD-'+tab);if(!dd)return;
	  dd.innerHTML='';
	  CURRENCIES.forEach(function(c){
	    var d=document.createElement('div');
	    d.className='cur-opt'+(selectedCurrency===c.code?' sel':'');
	    d.innerHTML='<span class="cur-opt-code">'+c.code+'</span><span class="cur-opt-nm">'+c.name+'</span>';
	    d.onclick=function(){selectCur(c.code,c.name);};
	    dd.appendChild(d);
	  });
	}
	function toggleCurDD(tab){
	  var dd=document.getElementById('curDD-'+tab),arr=document.getElementById('curArr-'+tab);
	  if(!dd)return;
	  var isOpen=dd.style.display!=='none';
	  ['dob','pen'].forEach(function(t){var d=document.getElementById('curDD-'+t),a=document.getElementById('curArr-'+t);if(d)d.style.display='none';if(a)a.classList.remove('open');});
	  if(!isOpen){buildCurDD(tab);dd.style.display='block';arr.classList.add('open');}
	}
	function selectCur(code,name){
	  selectedCurrency=code;
	  ['dob','pen'].forEach(function(t){
	    var ce=document.getElementById('curCode-'+t),ne=document.getElementById('curNm-'+t);
	    var dd=document.getElementById('curDD-'+t),arr=document.getElementById('curArr-'+t);
	    if(ce)ce.textContent=code;if(ne)ne.textContent=name;
	    if(dd)dd.style.display='none';if(arr)arr.classList.remove('open');
	  });
	}
	document.addEventListener('click',function(e){if(!e.target.closest('.cur-wrap')){['dob','pen'].forEach(function(t){var d=document.getElementById('curDD-'+t),a=document.getElementById('curArr-'+t);if(d)d.style.display='none';if(a)a.classList.remove('open');});}});

	function pR(s){var p=s.split('.');return new Date(+p[2],+p[1]-1,+p[0])}
	function fR(d){return String(d.getDate()).padStart(2,'0')+'.'+String(d.getMonth()+1).padStart(2,'0')+'.'+d.getFullYear()}
	function fI(d){return d.toISOString().split('T')[0]}
	function fD(d){return String(d.getDate()).padStart(2,'0')+'/'+String(d.getMonth()+1).padStart(2,'0')+'/'+d.getFullYear()}
	function pD(s){if(s.indexOf('-')>-1){var p=s.split('-');return new Date(+p[0],+p[1]-1,+p[2])}if(s.indexOf('/')>-1){var p=s.split('/');return new Date(+p[2],+p[1]-1,+p[0])}return pR(s)}
	function fM(n){return n.toLocaleString('ro-MD',{minimumFractionDigits:2,maximumFractionDigits:2})}
	function aDD(d,n){var r=new Date(d);r.setDate(r.getDate()+n);return r}
	function dD(a,b){return Math.round((b-a)/864e5)}

	function ST(t){
	document.querySelectorAll('.tab').forEach(function(x){x.classList.remove('active')});
	document.querySelectorAll('.tc').forEach(function(x){x.classList.remove('active')});
	document.querySelector('.tab[onclick*="'+t+'"]').classList.add('active');
	document.getElementById('tab-'+t).classList.add('active');
	}

