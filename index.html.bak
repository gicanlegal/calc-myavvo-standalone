	  if(localStorage.getItem('theme')==='dark'){
	    document.documentElement.setAttribute('data-theme','dark');
	    var icon=document.getElementById('themeIcon');
	    if(icon)icon.textContent='☀';
	  }
	});

	function iR(){
	try{var s=localStorage.getItem(SK);if(s){var d=JSON.parse(s);
	if(d.r&&d.r.length>0){RB=d.r.map(function(x){return{ds:pR(x.d),r:x.r,s:x.d}}).sort(function(a,b){return b.ds-a.ds});
	uI();if((new Date()-new Date(d.t))/36e5>24)AR();
	else{sRS('OK','ok');setTimeout(hRS,2e3)}return;}}}catch(e){}
	RB=RD.map(function(x){return{ds:pR(x.d),r:x.r,s:x.d}}).sort(function(a,b){return b.ds-a.ds});uI();AR();
	}

	function uI(){
	if(!RB.length)return;
	document.getElementById('rc').textContent=RB.length;
	document.getElementById('rf').textContent=fR(RB[RB.length-1].ds);
	document.getElementById('rto').textContent=fR(RB[0].ds);
	}

	function AR(){
	fetch(BU).then(function(r){return r.text()}).then(function(h){
	var n=pHtml(h);if(n.length>0){var m=new Map();
	RD.forEach(function(x){m.set(x.d,x.r)});
	RB.forEach(function(x){m.set(x.s,x.r)});
	n.forEach(function(x){m.set(x.s,x.r)});
	var a=[];m.forEach(function(v,k){a.push({d:k,r:v})});
	localStorage.setItem(SK,JSON.stringify({r:a,t:new Date().toISOString()}));
	RB=a.map(function(x){return{ds:pR(x.d),r:x.r,s:x.d}}).sort(function(a,b){return b.ds-a.ds});
	uI();sRS(RB.length+' rate','ok');}else{sRS('Parse error','er');}
	}).catch(function(){sRS('Date locale','ok');setTimeout(hRS,3e3)});
	}

	function pHtml(h){
	var r=[];try{var d=new DOMParser().parseFromString(h,'text/html');
	var t=d.querySelectorAll('table');
	for(var i=0;i<t.length;i++){
	if(t[i].textContent.toLowerCase().indexOf('rata de baz')===-1)continue;
	var w=t[i].querySelectorAll('tr');
	for(var j=1;j<w.length;j++){var c=w[j].querySelectorAll('td');
	if(c.length>=3){var dm=c[0].textContent.match(/(\d{2})\.(\d{2})\.(\d{4})/);
	var rm=c[2].textContent.match(/([\d,\.]+)/);
	if(dm&&rm){var v=parseFloat(rm[1].replace(',','.'));
	if(v>0&&v<50)r.push({ds:pR(dm[1]+'.'+dm[2]+'.'+dm[3]),r:v,s:dm[1]+'.'+dm[2]+'.'+dm[3]});}}}
	if(r.length)break;}}catch(e){}
	return r.sort(function(a,b){return b.ds-a.ds});
	}

	function sRS(m,t){var e=document.getElementById('rS');e.textContent=m;e.className='rs2 show '+t}
	function hRS(){document.getElementById('rS').classList.remove('show')}
	function sSB(id,m){var e=document.getElementById(id);if(!m){e.classList.remove('show');return;}e.textContent=m;e.className='sb show er'}
	function showErr(msg,targetId){
	  if(targetId){var el=document.getElementById(targetId);
	    if(el){var card=el.closest('.card')||el;
	      card.scrollIntoView({behavior:'smooth',block:'center'});
	      el.classList.add('field-err');
	      setTimeout(function(){el.classList.remove('field-err');},3500);
	    }
	  }
	  setTimeout(function(){
	    document.getElementById('errMsg').textContent=msg;
	    document.getElementById('errModal').style.display='flex';
	  },350);
	}
	function closeErr(){document.getElementById('errModal').style.display='none';}
	function gR(d){for(var i=0;i<RB.length;i++)if(d>=RB[i].ds)return RB[i].r;return RB[RB.length-1].r}
	// art.874 alin.(2): sem.I = rata la 1 ian, sem.II = rata la 1 iul
	function gRS(d){var y=d.getFullYear();var ref=d.getMonth()<6?new Date(y,0,1):new Date(y,6,1);return gR(ref)}

	function mkIB(pre,cnt,list){
	var d=document.createElement('div');d.className='ib';d.id=pre+cnt;
	d.innerHTML='<div class="ir"><div class="fg"><label>Data scadenței</label><input type="text" class="fd date-input" placeholder="zz/ll/aaaa" inputmode="numeric" maxlength="10" aria-label="Data scadenței"></div><div class="fg"><label>Suma</label><input type="number" class="fs" placeholder="10000" step="0.01"></div></div><button class="br" onclick="this.parentElement.remove()">Șterge</button>';
	document.getElementById(list).appendChild(d);
	}
	function mkPB(pre,cnt,list){
	var d=document.createElement('div');d.className='ib';d.id=pre+cnt;
	d.innerHTML='<div class="ir"><div class="fg"><label>Data plată</label><input type="text" class="pd date-input" placeholder="zz/ll/aaaa" inputmode="numeric" maxlength="10" aria-label="Data plată"></div><div class="fg"><label>Suma</label><input type="number" class="ps" placeholder="5000" step="0.01"></div></div><button class="br" onclick="this.parentElement.remove()">Șterge</button>';
	document.getElementById(list).appendChild(d);
	}
	function aF(){fi++;mkIB('f',fi,'fL')}
	function aP(){pi++;mkPB('p',pi,'pL')}
	function aPF(){pfi++;mkIB('xf',pfi,'pfL')}
	function aPP(){ppi++;mkPB('xp',ppi,'ppL')}

	function gF(l){var f=[];document.querySelectorAll('#'+l+' .ib').forEach(function(i){
	var d=i.querySelector('.fd'),s=i.querySelector('.fs');
	if(d&&s&&d.value&&parseFloat(s.value)>0)f.push({data:pD(d.value),suma:parseFloat(s.value)});
	});return f.sort(function(a,b){return a.data-b.data})}

	function gP(l){var p=[];document.querySelectorAll('#'+l+' .ib').forEach(function(i){
	var d=i.querySelector('.pd'),s=i.querySelector('.ps');
	if(d&&s&&d.value&&parseFloat(s.value)>0)p.push({data:pD(d.value),suma:parseFloat(s.value)});
	});return p.sort(function(a,b){return a.data-b.data})}
	
	function cD(){
	try{
	var f=gF('fL'),pl=gP('pL'),dc=document.getElementById('dC').value;
	var Y=+document.querySelector('input[name="pY"]:checked').value;
	if(!f.length){showErr('Adăugați cel puțin o sumă scadentă cu data și suma completate!','fL');return;}
	if(!dc){showErr('Selectați data calculului!','dC');return;}
	var D=pD(dc),ps=f[0].data;
	if(D<=ps){showErr('Data calculului trebuie să fie după data primei scadențe!','dC');return;}
	var ev=[];
	f.forEach(function(x){ev.push({d:x.data,t:'s',v:x.suma})});
	var avans=0;
	pl.forEach(function(x){if(x.data<ps){avans+=x.suma;}else if(x.data<=D){ev.push({d:x.data,t:'p',v:x.suma});}});
	// Frontiere de semestru (1 ian si 1 iul) intre ps si D
	for(var bYr=ps.getFullYear();bYr<=D.getFullYear()+1;bYr++){
	var bJ=new Date(bYr,0,1),bJu=new Date(bYr,6,1);
	if(bJ>ps&&bJ<=D)ev.push({d:bJ,t:'r',v:gR(bJ)});
	if(bJu>ps&&bJu<=D)ev.push({d:bJu,t:'r',v:gR(bJu)});}
	ev.sort(function(a,b){return a.d-b.d});
	var inclS=document.querySelector('input[name="incS"]:checked').value==='1';
	var T=[],s=0,r=gRS(ps),c=0,z=null,tF=0,tP=0;
	for(var i=0;i<ev.length;i++){var e=ev[i];
	if(z&&e.d>z&&s>0){var a2=aDD(z,1),b2=aDD(e.d,-1);
	if(b2>=a2){var n=dD(a2,b2)+1,rt=r+Y,db=s*(rt/100)/365*n;c+=db;
	T.push({a:a2,b:b2,z:n,s:s,r:r,rt:rt,db:db,c:c,o:''});}}
	if(e.t==='s'){T.push({a:e.d,b:null,z:0,s:s+e.v,r:r,rt:r+Y,db:0,c:c,o:'Scadenta +'+fM(e.v),iS:1});s+=e.v;tF+=e.v;
	if(avans>0&&e.d.getTime()===ps.getTime()){s=Math.max(0,s-avans);tP+=avans;T.push({a:e.d,b:null,z:0,s:s,r:r,rt:r+Y,db:0,c:c,o:'Avans -'+fM(avans),iP:1});}
	z=inclS?aDD(e.d,-1):e.d;}
	else if(e.t==='p'){s=Math.max(0,s-e.v);T.push({a:e.d,b:null,z:0,s:s,r:r,rt:r+Y,db:0,c:c,o:'Plata -'+fM(e.v),iP:1});tP+=e.v;z=e.d;}
	else{r=e.v;if(z)z=aDD(e.d,-1);}}
	if(z&&D>z&&s>0){var a2=aDD(z,1);if(D>=a2){var n=dD(a2,D)+1,rt=r+Y,db=s*(rt/100)/365*n;c+=db;
	T.push({a:a2,b:D,z:n,s:s,r:r,rt:rt,db:db,c:c,o:''});}}
	var zt=0;T.forEach(function(x){zt+=x.z});
	rDob={T:T,tot:c,tF:tF,tP:tP,zt:zt,Y:Y,D:D,ps:ps};shD();sSB('sB','');
	}catch(e){showErr(typeof e==='string'?e:'A apărut o eroare la calculare.')}}

	function expandDetaliat(T){
	var res=[];
	T.forEach(function(w){
	if(!w.b||w.z===0){res.push(w);}
	else{var dd=w.s*(w.rt/100)/365,cB=w.c-w.db,cur=new Date(w.a.getTime()),end=new Date(w.b.getTime()),rc=cB;
	while(cur<=end){rc+=dd;res.push({a:new Date(cur.getTime()),b:new Date(cur.getTime()),z:1,s:w.s,r:w.r,rt:w.rt,db:dd,c:rc,o:''});cur=aDD(cur,1);}}});
	return res;}

	function shD(){
	document.getElementById('dI').style.display='none';
	document.getElementById('dR').classList.add('show');
	var r=rDob;
	document.getElementById('dT').textContent=fM(r.tot)+' '+getCurrency();
	document.getElementById('dP').textContent=fR(r.ps)+' - '+fR(r.D);
	document.getElementById('d1').textContent=fM(r.tF);
	document.getElementById('d2').textContent=fM(r.tP);
	document.getElementById('d3').textContent=r.zt;
	document.getElementById('d4').textContent='+'+r.Y+'%';
	var modD=document.querySelector('input[name="modD"]:checked').value==='1';
	fillTbl('dTB',modD?expandDetaliat(r.T):r.T,r.zt,r.tot,true);
	}

	function fillTbl(id,T,zt,tot,showR){
	var tb=document.getElementById(id);tb.innerHTML='';
	T.forEach(function(w){var tr=document.createElement('tr');
	if(w.iS)tr.className='sr';else if(w.iP)tr.className='pr';else if(w.o==='LIMITA')tr.className='lr';
	var p=w.b?(w.z===1?fR(w.a):fR(w.a)+'-'+fR(w.b)):fR(w.a);
	var h='<td>'+p+'</td><td style="text-align:center">'+(w.z||'-')+'</td><td style="text-align:right">'+fM(w.s)+'</td>';
	if(showR)h+='<td style="text-align:center">'+w.r.toFixed(2)+'%</td><td style="text-align:center">'+w.rt.toFixed(2)+'%</td>';
	else h+='<td style="text-align:center">'+w.rt+'%</td>';
	h+='<td style="text-align:right">'+(w.db>0?fM(w.db):'-')+'</td><td style="text-align:right">'+fM(w.c)+'</td><td style="font-size:.6rem">'+w.o+'</td>';
	tr.innerHTML=h;tb.appendChild(tr);});
	var t=document.createElement('tr');t.className='xtr';
	var cs=showR?4:3;
	t.innerHTML='<td><strong>TOTAL</strong></td><td style="text-align:center"><strong>'+zt+'</strong></td><td colspan="'+cs+'"></td><td style="text-align:right"><strong>'+fM(tot)+'</strong></td><td></td>';
	tb.appendChild(t);
	}

	function loadLogoAndQr(callback){var logo=new Image();var qr=new Image();var logoLoaded=false,qrLoaded=false;var logoB64=null,qrB64=null;function toB64(img){var c=document.createElement('canvas');c.width=img.width;c.height=img.height;var ctx=c.getContext('2d');ctx.drawImage(img,0,0);return c.toDataURL('image/png');}function check(){if(logoLoaded&&qrLoaded)callback(logoB64,qrB64);}logo.onload=function(){logoB64=toB64(logo);logoLoaded=true;check();};logo.onerror=function(){logoLoaded=true;check();};logo.src='logo.png';qr.onload=function(){qrB64=toB64(qr);qrLoaded=true;check();};qr.onerror=function(){qrLoaded=true;check();};qr.src='qr-calc.png';}
	function _pdfHdr(doc,logoB64,qrB64){
	  var nv=[26,54,93],tl=[56,178,172],gr=[113,128,150];
	  var pageW=doc.internal.pageSize.getWidth();
	  // Logo text "myAVVO"
	  doc.setFont('helvetica','bold');doc.setFontSize(16);
	  doc.setTextColor(56,178,172);doc.text('my',10,14);
	  var myW=doc.getTextWidth('my');
	  doc.setTextColor(26,54,93);doc.text('AVVO',10+myW,14);
	  // Titlu si subtitlu
	  doc.setFont('helvetica','bold');doc.setFontSize(9);
	  doc.setTextColor(nv[0],nv[1],nv[2]);
	  doc.text('HUB Juridic Unic in Moldova',10,22);
	  doc.setFont('helvetica','normal');doc.setFontSize(7.5);
	  doc.setTextColor(74,85,104);
	  doc.text('Toate solutiile juridice intr-un singur loc',10,27);
	  // QR cod
	  var qrX=pageW-38,qrY=8,qrSize=26;
	  if(qrB64){doc.addImage(qrB64,'PNG',qrX,qrY,qrSize,qrSize);}
	  doc.setFontSize(6);doc.setTextColor(gr[0],gr[1],gr[2]);
	  doc.text('calc.myavvo.md',qrX+qrSize/2,qrY+qrSize+4,{align:'center'});
	  // Linie separator
	  doc.setDrawColor(nv[0],nv[1],nv[2]);doc.setLineWidth(0.5);doc.line(10,40,pageW-10,40);
	  return 46;
	}
	function _pdfFtr(doc,dateStr){var ML=14,MR=196;var nv=[26,54,93],tl=[56,178,172],gr=[113,128,150];var H=doc.internal.pageSize.getHeight();var tp=doc.internal.getNumberOfPages();for(var p=1;p<=tp;p++){doc.setPage(p);doc.setDrawColor(nv[0],nv[1],nv[2]);doc.setLineWidth(0.4);doc.line(ML,H-20,MR,H-20);doc.setFont('helvetica','bold');doc.setFontSize(7);doc.setTextColor(nv[0],nv[1],nv[2]);doc.text('myAVVO \u2014 Hub Juridic Moldova',ML,H-15.5);doc.setFont('helvetica','normal');doc.setFontSize(6);doc.setTextColor(gr[0],gr[1],gr[2]);doc.text('Solutii juridice complete pentru business si persoane fizice',ML,H-12);doc.setTextColor(tl[0],tl[1],tl[2]);doc.text('calc.myavvo.md',ML,H-8.5);doc.setTextColor(gr[0],gr[1],gr[2]);doc.setFontSize(6.5);doc.text('Document generat automat',MR,H-15.5,{align:'right'});doc.text(dateStr,MR,H-12,{align:'right'});doc.text('Pagina '+p+' / '+tp,MR,H-8.5,{align:'right'});}}
	function _pdfCheck(){if(typeof window.jspdf==='undefined'){alert('jsPDF nu este incarcat. Reincarca pagina.');return false;}return true;}
	function noDiac(s){return s.replace(/[ăâ]/g,'a').replace(/[ĂÂ]/g,'A').replace(/î/g,'i').replace(/Î/g,'I').replace(/[șş]/g,'s').replace(/[ȘŞ]/g,'S').replace(/[țţ]/g,'t').replace(/[ȚŢ]/g,'T');}
	function _pdfDate(){var n=new Date();function p(x){return String(x).padStart(2,'0');}return{str:fR(n)+' '+p(n.getHours())+':'+p(n.getMinutes()),file:n.getFullYear()+''+p(n.getMonth()+1)+''+p(n.getDate())};}
	function _pdfStats(doc,stats,x,y,uw){var bW=(uw-9)/4;var nv=[26,54,93],gr=[113,128,150],bgA=[247,250,252],bgB=[226,232,240];stats.forEach(function(st,i){var bx=x+i*(bW+3);doc.setFillColor(bgA[0],bgA[1],bgA[2]);doc.setDrawColor(bgB[0],bgB[1],bgB[2]);doc.setLineWidth(0.3);doc.roundedRect(bx,y,bW,16,2,2,'FD');doc.setFont('helvetica','normal');doc.setFontSize(6.5);doc.setTextColor(gr[0],gr[1],gr[2]);doc.text(st.l,bx+bW/2,y+5.5,{align:'center'});doc.setFont('helvetica','bold');doc.setFontSize(8.5);doc.setTextColor(nv[0],nv[1],nv[2]);doc.text(st.v,bx+bW/2,y+12.5,{align:'center'});});}

	function eDP(){if(!rDob||!_pdfCheck())return;loadLogoAndQr(function(logoB64,qrB64){var jsPDF=window.jspdf.jsPDF;var doc=new jsPDF({orientation:'p',unit:'mm',format:'a4'});
	var r=rDob;var ML=14,MR=196,UW=182;var nv=[26,54,93],tl=[56,178,172],gr=[113,128,150],dg=[45,55,72];var bgA=[247,250,252],bgB=[226,232,240];var dt=_pdfDate();var cur=getCurrency();
	var pageW=doc.internal.pageSize.getWidth();var y=_pdfHdr(doc,logoB64,qrB64);
	var intro='Dobanda legala constituie \u2014 '+fM(r.tot)+' '+cur+' si a fost calculata pentru perioada '+fR(r.ps)+' - '+fR(r.D)+', conform art. 874 Cod Civil RM, rata BNM + '+r.Y+'% (persoane '+(r.Y===5?'fizice':'juridice')+').';
	doc.setFont('helvetica','normal');doc.setFontSize(8.5);doc.setTextColor(dg[0],dg[1],dg[2]);var iL=doc.splitTextToSize(intro,UW);doc.text(iL,ML,y);y+=iL.length*4.5+3;
	var boxW=130;var boxX=(pageW-boxW)/2;var boxH=24;doc.setFillColor(235,248,255);doc.roundedRect(boxX,y,boxW,boxH,3,3,'F');doc.setDrawColor(56,178,172);doc.setLineWidth(0.5);doc.roundedRect(boxX,y,boxW,boxH,3,3,'S');doc.setFontSize(8);doc.setTextColor(44,122,122);doc.setFont('helvetica','normal');doc.text('Dobanda legala de intarziere',pageW/2,y+6,{align:'center'});doc.setFontSize(18);doc.setFont('helvetica','bold');doc.setTextColor(26,54,93);doc.text(fM(r.tot)+' '+cur,pageW/2,y+15,{align:'center'});doc.setFontSize(8);doc.setFont('helvetica','normal');doc.setTextColor(74,85,104);doc.text(fR(r.ps)+' \u2014 '+fR(r.D),pageW/2,y+21,{align:'center'});y+=boxH+4;
	_pdfStats(doc,[{l:'Sume scadente',v:fM(r.tF)+' '+cur},{l:'Achitat',v:fM(r.tP)+' '+cur},{l:'Zile calculate',v:String(r.zt)},{l:'Procent suplimentar',v:'+'+r.Y+'%'}],ML,y,UW);y+=20;
	var modD=document.querySelector('input[name="modD"]:checked').value==='1';var tX=modD?expandDetaliat(r.T):r.T;var rows=[],rCls=[];
	tX.forEach(function(w){var p=w.b?(w.z===1?fR(w.a):fR(w.a)+'-'+fR(w.b)):fR(w.a);rows.push([p,w.z||'-',fM(w.s),(w.r||0).toFixed(2)+'%',(w.rt||0).toFixed(2)+'%',w.db>0?fM(w.db):'-',fM(w.c),w.o||'']);rCls.push(w.iS?'sc':w.iP?'pl':'');});
	rows.push(['TOTAL',String(r.zt),'','','','',fM(r.tot),'']);rCls.push('tot');
	doc.autoTable({startY:y,head:[['Perioada','Zile','Suma '+cur,'BNM%','Total%','Dobanda','Cumulat','Obs']],body:rows,theme:'grid',styles:{fontSize:7.5,cellPadding:2,lineColor:bgB,lineWidth:0.2},headStyles:{fillColor:nv,textColor:[255,255,255],fontStyle:'bold',fontSize:7.5,halign:'center'},alternateRowStyles:{fillColor:bgA},columnStyles:{0:{cellWidth:32},1:{halign:'center',cellWidth:9},2:{halign:'right',cellWidth:23},3:{halign:'center',cellWidth:13},4:{halign:'center',cellWidth:13},5:{halign:'right',cellWidth:23},6:{halign:'right',cellWidth:23},7:{cellWidth:46}},margin:{left:ML,right:14,top:46,bottom:22},didParseCell:function(data){if(data.section==='body'){var c=rCls[data.row.index];if(c==='sc'){data.cell.styles.fillColor=[255,251,235];data.cell.styles.textColor=[183,121,31];}else if(c==='pl'){data.cell.styles.fillColor=[240,255,244];data.cell.styles.textColor=[39,103,73];}else if(c==='tot'){data.cell.styles.fillColor=[235,248,255];data.cell.styles.textColor=nv;data.cell.styles.fontStyle='bold';}}},didDrawPage:function(data){if(data.pageNumber>1)_pdfHdr(doc,logoB64,qrB64);}});
	var fy=doc.lastAutoTable.finalY+4;doc.setLineWidth(1.5);doc.setDrawColor(nv[0],nv[1],nv[2]);doc.line(ML,fy,ML+UW/2,fy);doc.setDrawColor(tl[0],tl[1],tl[2]);doc.line(ML+UW/2,fy,MR,fy);
	var sy=fy+9;var nome=getPdfNume();doc.setFont('helvetica','normal');doc.setFontSize(10);doc.setTextColor(dg[0],dg[1],dg[2]);doc.text('Calcul efectuat de: '+(nome||'___________________________'),ML,sy);doc.setDrawColor(nv[0],nv[1],nv[2]);doc.setLineWidth(0.4);doc.line(ML,sy+10,ML+60,sy+10);doc.setFont('helvetica','normal');doc.setFontSize(8);doc.setTextColor(gr[0],gr[1],gr[2]);doc.text('Semnatura',ML+30,sy+15,{align:'center'});
	_pdfFtr(doc,dt.str);doc.save('myavvo-dobanda-'+dt.file+'.pdf');});}

	function cP(){
	try{
	var pr=parseFloat(document.getElementById('pPr').value);
	if(!pr||pr<=0){showErr('Introduceți procentul penalității (% pe zi)!','pPr');return;}
	var f=gF('pfL'),pl=gP('ppL'),dc=document.getElementById('pDC').value;
	var lim=+document.querySelector('input[name="pLim"]:checked').value;
	if(!f.length){showErr('Adăugați cel puțin o sumă scadentă cu data și suma completate!','pfL');return;}
	if(!dc){showErr('Selectați data calculului!','pDC');return;}
	var D=pD(dc),ps=f[0].data;
	if(D<=ps){showErr('Data calculului trebuie să fie după data primei scadențe!','pDC');return;}
	var ev=[];
	f.forEach(function(x){ev.push({d:x.data,t:'s',v:x.suma})});
	var avans=0;
	pl.forEach(function(x){if(x.data<ps){avans+=x.suma;}else if(x.data<=D){ev.push({d:x.data,t:'p',v:x.suma});}});
	ev.sort(function(a,b){return a.d-b.d});
	var inclSP=document.querySelector('input[name="incSP"]:checked').value==='1';
	var T=[],s=0,c=0,z=null,tF=0,tP=0,zC=0,limOK=false,limTx='';
	for(var i=0;i<ev.length;i++){var e=ev[i];
	if(limOK)break;
	if(z&&e.d>z&&s>0){var a2=aDD(z,1),b2=aDD(e.d,-1);
	if(b2>=a2){var n=dD(a2,b2)+1;
	if(lim>0&&zC+n>lim){n=lim-zC;b2=aDD(a2,n-1);limOK=true;limTx='Limita '+(lim===180?'180 zile':'3 ani')+' atinsă la '+fR(b2)}
	if(n>0){var pen=s*(pr/100)*n;c+=pen;zC+=n;
	T.push({a:a2,b:b2,z:n,s:s,r:0,rt:pr,db:pen,c:c,o:limOK?'LIMITA':''});}}}
	if(!limOK){
	if(e.t==='s'){T.push({a:e.d,b:null,z:0,s:s+e.v,r:0,rt:pr,db:0,c:c,o:'Scadenta +'+fM(e.v),iS:1});s+=e.v;tF+=e.v;
	if(avans>0&&e.d.getTime()===ps.getTime()){s=Math.max(0,s-avans);tP+=avans;T.push({a:e.d,b:null,z:0,s:s,r:0,rt:pr,db:0,c:c,o:'Avans -'+fM(avans),iP:1});}
	z=inclSP?aDD(e.d,-1):e.d;}
	else if(e.t==='p'){s=Math.max(0,s-e.v);T.push({a:e.d,b:null,z:0,s:s,r:0,rt:pr,db:0,c:c,o:'Plata -'+fM(e.v),iP:1});tP+=e.v;z=e.d;}}}
	if(!limOK&&z&&D>z&&s>0){var a2=aDD(z,1);if(D>=a2){var n=dD(a2,D)+1;var b2=D;
	if(lim>0&&zC+n>lim){n=lim-zC;b2=aDD(a2,n-1);limOK=true;limTx='Limita '+(lim===180?'180 zile':'3 ani')+' atinsă la '+fR(b2)}
	if(n>0){var pen=s*(pr/100)*n;c+=pen;zC+=n;
	T.push({a:a2,b:b2,z:n,s:s,r:0,rt:pr,db:pen,c:c,o:limOK?'LIMITA':''});}}}
	rPen={T:T,tot:c,tF:tF,tP:tP,zt:zC,pr:pr,D:D,ps:ps,lim:lim,limTx:limTx};shP();sSB('pSB','');
	}catch(e){showErr(typeof e==='string'?e:'A apărut o eroare la calculare.')}}

	function shP(){
	document.getElementById('pI').style.display='none';
	document.getElementById('pR').classList.add('show');
	var r=rPen;
	document.getElementById('pT').textContent=fM(r.tot)+' '+getCurrency();
	document.getElementById('pPe').textContent=fR(r.ps)+' - '+fR(r.D);
	document.getElementById('p1').textContent=fM(r.tF);
	document.getElementById('p2').textContent=fM(r.tP);
	document.getElementById('p3').textContent=r.zt;
	document.getElementById('p4').textContent=r.pr+'%';
	var li=document.getElementById('pLI');
	if(r.limTx){li.style.display='block';li.textContent=r.limTx}else li.style.display='none';
	var modP=document.querySelector('input[name="modP"]:checked').value==='1';
	fillTbl('pTB',modP?expandDetaliat(r.T):r.T,r.zt,r.tot,false);
	}


	function ePP2(){if(!rPen||!_pdfCheck())return;loadLogoAndQr(function(logoB64,qrB64){var jsPDF=window.jspdf.jsPDF;var doc=new jsPDF({orientation:'p',unit:'mm',format:'a4'});
	var r=rPen;var ML=14,MR=196,UW=182;var nv=[26,54,93],tl=[56,178,172],gr=[113,128,150],dg=[45,55,72];var bgA=[247,250,252],bgB=[226,232,240];var dt=_pdfDate();var cur=getCurrency();
	var pageW=doc.internal.pageSize.getWidth();var y=_pdfHdr(doc,logoB64,qrB64);
	var intro=noDiac('Penalitatea contractuala constituie \u2014 '+fM(r.tot)+' '+cur+' si a fost calculata pentru perioada '+fR(r.ps)+' - '+fR(r.D)+', in baza clauzei penale de '+r.pr+'% pe zi din suma datoriei neachitate.'+(r.limTx?' Nota: '+r.limTx+'.':''));
	doc.setFont('helvetica','normal');doc.setFontSize(8.5);doc.setTextColor(dg[0],dg[1],dg[2]);var iL=doc.splitTextToSize(intro,UW);doc.text(iL,ML,y);y+=iL.length*4.5+3;
	var boxW=130;var boxX=(pageW-boxW)/2;var boxH=24;doc.setFillColor(235,248,255);doc.roundedRect(boxX,y,boxW,boxH,3,3,'F');doc.setDrawColor(56,178,172);doc.setLineWidth(0.5);doc.roundedRect(boxX,y,boxW,boxH,3,3,'S');doc.setFontSize(8);doc.setTextColor(44,122,122);doc.setFont('helvetica','normal');doc.text('Penalitate contractuala totala',pageW/2,y+6,{align:'center'});doc.setFontSize(18);doc.setFont('helvetica','bold');doc.setTextColor(26,54,93);doc.text(fM(r.tot)+' '+cur,pageW/2,y+15,{align:'center'});doc.setFontSize(8);doc.setFont('helvetica','normal');doc.setTextColor(74,85,104);doc.text(fR(r.ps)+' \u2014 '+fR(r.D),pageW/2,y+21,{align:'center'});y+=boxH+4;
	var limStr=r.lim===0?'Fara limita':r.lim===180?'180 zile':'3 ani';
	_pdfStats(doc,[{l:'Sume scadente',v:fM(r.tF)+' '+cur},{l:'Achitat',v:fM(r.tP)+' '+cur},{l:'Zile calculate',v:String(r.zt)},{l:'Limita',v:limStr}],ML,y,UW);y+=20;
	var modP=document.querySelector('input[name="modP"]:checked').value==='1';var tX=modP?expandDetaliat(r.T):r.T;var rows=[],rCls=[];
	tX.forEach(function(w){var p=w.b?(w.z===1?fR(w.a):fR(w.a)+'-'+fR(w.b)):fR(w.a);rows.push([p,w.z||'-',fM(w.s),(w.rt||0)+'%',w.db>0?fM(w.db):'-',fM(w.c),w.o||'']);rCls.push(w.iS?'sc':w.iP?'pl':w.o==='LIMITA'?'lm':'');});
	rows.push(['TOTAL',String(r.zt),'','','',fM(r.tot),'']);rCls.push('tot');
	doc.autoTable({startY:y,head:[['Perioada','Zile','Suma '+cur,'%/zi','Penalitate','Cumulat','Obs']],body:rows,theme:'grid',styles:{fontSize:7.5,cellPadding:2,lineColor:bgB,lineWidth:0.2},headStyles:{fillColor:nv,textColor:[255,255,255],fontStyle:'bold',fontSize:7.5,halign:'center'},alternateRowStyles:{fillColor:bgA},columnStyles:{0:{cellWidth:33},1:{halign:'center',cellWidth:10},2:{halign:'right',cellWidth:27},3:{halign:'center',cellWidth:15},4:{halign:'right',cellWidth:26},5:{halign:'right',cellWidth:26},6:{cellWidth:45}},margin:{left:ML,right:14,top:46,bottom:22},didParseCell:function(data){if(data.section==='body'){var c=rCls[data.row.index];if(c==='sc'){data.cell.styles.fillColor=[255,251,235];data.cell.styles.textColor=[183,121,31];}else if(c==='pl'){data.cell.styles.fillColor=[240,255,244];data.cell.styles.textColor=[39,103,73];}else if(c==='lm'){data.cell.styles.fillColor=[254,226,226];data.cell.styles.textColor=[185,28,28];}else if(c==='tot'){data.cell.styles.fillColor=[235,248,255];data.cell.styles.textColor=nv;data.cell.styles.fontStyle='bold';}}},didDrawPage:function(data){if(data.pageNumber>1)_pdfHdr(doc,logoB64,qrB64);}});
	var fy=doc.lastAutoTable.finalY+4;doc.setLineWidth(1.5);doc.setDrawColor(nv[0],nv[1],nv[2]);doc.line(ML,fy,ML+UW/2,fy);doc.setDrawColor(tl[0],tl[1],tl[2]);doc.line(ML+UW/2,fy,MR,fy);
	var sy=fy+9;var nome=getPdfNume();doc.setFont('helvetica','normal');doc.setFontSize(10);doc.setTextColor(dg[0],dg[1],dg[2]);doc.text('Calcul efectuat de: '+(nome||'___________________________'),ML,sy);doc.setDrawColor(nv[0],nv[1],nv[2]);doc.setLineWidth(0.4);doc.line(ML,sy+10,ML+60,sy+10);doc.setFont('helvetica','normal');doc.setFontSize(8);doc.setTextColor(gr[0],gr[1],gr[2]);doc.text('Semnatura',ML+30,sy+15,{align:'center'});
	_pdfFtr(doc,dt.str);doc.save('myavvo-penalitate-'+dt.file+'.pdf');});}

