<!DOCTYPE html>
<!-- v2.1 deploy via GitHub Actions SCP -->
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Calculator Juridic</title>
<meta name="description" content="Calculator juridic: dobândă legală, penalitate, taxa de stat. Conform legislației Republicii Moldova.">
<link rel="icon" href="/logo.png" type="image/png">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Roboto:wght@700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.6.0/jspdf.plugin.autotable.min.js"></script>
<style>
/* ── Tema deschisa (default) ── */
:root{
--primary:#1a365d;--primary-light:#2a4a7f;
--accent:#38b2ac;--accent-light:#4fd1c5;--accent-dark:#2c9490;
--bg:#f7fafc;--surface:#ffffff;--surface-2:#edf2f7;
--border:#e2e8f0;--border-2:#cbd5e0;
--text-primary:#1a202c;--text-secondary:#4a5568;--text-muted:#718096;
--input-bg:#ffffff;--input-border:#cbd5e0;
--tab-active-bg:rgba(56,178,172,.12);--tab-active-border:#38b2ac;--tab-active-color:#1a365d;
--result-bg:#ffffff;--shadow:0 1px 3px rgba(0,0,0,.1);
--label:#2c9490;--accent-subtle:rgba(56,178,172,.1);--accent-border:rgba(56,178,172,.3);}
/* ── Tema inchisa ── */
[data-theme="dark"]{
--primary:#e2e8f0;--primary-light:#cbd5e0;
--accent:#4fd1c5;--accent-light:#81e6d9;--accent-dark:#38b2ac;
--bg:#0f172a;--surface:#1e293b;--surface-2:#1a2744;
--border:#2d3748;--border-2:#334155;
--text-primary:#f1f5f9;--text-secondary:#94a3b8;--text-muted:#64748b;
--input-bg:#0f172a;--input-border:#334155;
--tab-active-bg:rgba(79,209,197,.12);--tab-active-border:#4fd1c5;--tab-active-color:#4fd1c5;
--result-bg:#1e293b;--shadow:0 1px 3px rgba(0,0,0,.4);
--label:#38b2ac;--accent-subtle:rgba(79,209,197,.1);--accent-border:rgba(79,209,197,.3);}
/* ── Reset & base ── */
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);min-height:100vh;color:var(--text-primary);transition:background .2s,color .2s}
.hd{background:#1a365d;padding:0;position:sticky;top:0;z-index:200}
.ttl{display:none}
.tabs{display:flex;background:rgba(0,0,0,.2);border-radius:8px;padding:3px;gap:2px;margin:8px 0}
.tab{flex:1;padding:8px 6px;border-radius:6px;border:none;color:rgba(255,255,255,.45);font-size:.73rem;cursor:pointer;text-align:center;font-weight:500;transition:all .15s;font-family:inherit;white-space:nowrap;background:transparent}
.tab.active{background:#ffffff;color:#1a365d;font-weight:700;box-shadow:0 1px 3px rgba(0,0,0,.2)}
.tab:hover:not(.active){color:rgba(255,255,255,.75);background:rgba(255,255,255,.08)}
.mn{padding:0 14px 32px;max-width:900px;margin:0 auto;background:var(--bg);min-height:calc(100vh - 62px - 180px);overflow-x:hidden}
.tc{display:none;padding-top:14px}.tc.active{display:block}
.card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px;margin-bottom:12px;box-shadow:var(--shadow)}
.ct{font-size:.88rem;font-weight:600;margin-bottom:12px;display:flex;align-items:flex-start;gap:8px;color:var(--text-primary)}
.stp{background:linear-gradient(135deg,var(--accent),var(--accent-dark));color:#fff;min-width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700}
.fg{margin-bottom:12px}.fg:last-child{margin-bottom:0}
.fg label{display:block;color:var(--label);font-size:.78rem;font-weight:500;margin-bottom:4px}
.fg input,.fg select{width:100%;padding:10px;border-radius:8px;border:1px solid var(--input-border);background:var(--input-bg);color:var(--text-primary);font-size:.9rem}
.fg input:focus{outline:none;border-color:var(--accent)}
.fg select option{background:var(--surface)}
.fh{color:var(--text-muted);font-size:.68rem;margin-top:3px}
.row{display:flex;flex-direction:column;gap:10px}
@media(min-width:500px){.row{flex-direction:row}.row>.fg{flex:1}}
.rc{display:flex;flex-direction:column;gap:8px}
@media(min-width:450px){.rc{flex-direction:row}}
.ri{position:relative;flex:1}
.ri input[type=radio]{position:absolute;opacity:0;width:100%;height:100%;cursor:pointer;z-index:2}
.ri>label{display:block;padding:12px 8px;border-radius:10px;border:2px solid var(--border);background:var(--surface-2);text-align:center;cursor:pointer}
.ri input:checked+label{border-color:var(--accent);background:var(--accent-subtle)}
.ri .big{font-size:1.2rem;font-weight:700;color:var(--accent);display:block}
.ri .sm{font-size:.65rem;color:var(--text-secondary);margin-top:2px}
.sc{display:flex;flex-direction:column;gap:6px}
@media(min-width:500px){.sc{flex-direction:row;flex-wrap:wrap}.sc .ri{flex:1 1 45%}}
.ib{padding:10px;background:var(--surface-2);border-radius:8px;margin-bottom:8px;border:1px solid var(--border)}
.ir{display:flex;flex-direction:column;gap:8px}
@media(min-width:450px){.ir{flex-direction:row}.ir>.fg{flex:1}}
.ib .fg{margin-bottom:0}.ib label{font-size:.68rem;color:var(--text-muted)}.ib input{padding:9px;font-size:.85rem}
.br{background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.2);color:#ef4444;padding:5px 10px;border-radius:5px;cursor:pointer;font-size:.72rem;margin-top:5px}
.ba{background:var(--accent-subtle);border:1px dashed var(--accent-border);color:var(--label);padding:10px;border-radius:8px;cursor:pointer;font-size:.8rem;width:100%;margin-top:6px;text-align:center}
.bc{width:100%;padding:13px;border:none;border-radius:10px;background:linear-gradient(135deg,var(--accent),var(--accent-dark));color:#fff;font-size:.92rem;font-weight:600;cursor:pointer;margin-top:8px}
.bs{background:transparent!important;color:var(--accent)!important;border:2px solid var(--accent)!important;font-weight:600}
.bs:hover{background:var(--accent-subtle)!important}
.bpdf{background:linear-gradient(135deg,var(--accent),var(--accent-dark));color:#fff}
[data-theme="dark"] .bs{background:transparent!important;color:#4fd1c5!important;border:2px solid #4fd1c5!important}
[data-theme="dark"] .bs:hover{background:rgba(79,209,197,.1)!important}
[data-theme="dark"] .bpdf{color:#0f172a}
.rb2{background:var(--accent-subtle);border:1px solid var(--accent-border);border-radius:8px;padding:8px 12px;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:6px}
.rt2{font-size:.78rem;color:var(--label)}.rt2 strong{color:var(--text-primary)}
.bf{padding:5px 10px;border-radius:5px;border:1px solid var(--accent-border);background:var(--accent-subtle);color:var(--label);font-size:.72rem;cursor:pointer}
.rs2{font-size:.68rem;width:100%;margin-top:4px;padding:4px 8px;border-radius:4px;display:none}
.rs2.show{display:block}.rs2.ok{background:rgba(56,178,172,.15);color:var(--accent-dark)}.rs2.er{background:rgba(239,68,68,.1);color:#ef4444}
.sb{padding:8px 12px;border-radius:6px;margin-bottom:10px;font-size:.8rem;display:none}.sb.show{display:block}.sb.er{background:rgba(239,68,68,.12);color:#ef4444}
.rse{display:none}.rse.show{display:block}
.rca{background:linear-gradient(135deg,var(--accent-subtle),var(--result-bg));border:2px solid var(--accent-border)}
.rh{text-align:center;margin-bottom:14px}
.rl{color:var(--accent);font-size:.8rem;margin-bottom:4px}
.rv{font-size:1.8rem;font-weight:800;color:var(--accent)}
.rsu{color:var(--text-secondary);font-size:.75rem;margin-top:4px}
.rsum{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:12px;padding-top:12px;border-top:1px solid var(--border)}
@media(min-width:500px){.rsum{grid-template-columns:repeat(4,1fr)}}
.si{background:var(--surface-2);padding:8px 6px;border-radius:6px;text-align:center}
.si .sl{color:var(--text-secondary);font-size:.62rem}.si .sv{color:var(--text-primary);font-size:.82rem;font-weight:600;margin-top:2px}
.th{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;flex-wrap:wrap;gap:6px}
.tt2{font-size:.85rem;color:var(--text-primary)}
.eb{display:flex;gap:4px}
.be{padding:4px 10px;border-radius:5px;border:1px solid var(--accent-border);background:var(--accent-subtle);color:var(--label);font-size:.7rem;cursor:pointer}
.tw{overflow-x:auto;margin:0 -14px;padding:0 14px}
.tbl{width:100%;min-width:540px;border-collapse:collapse;font-size:.7rem}
.tbl th,.tbl td{padding:6px 4px;text-align:right;border-bottom:1px solid var(--border)}
.tbl th{background:var(--surface-2);color:var(--text-secondary);text-align:center;font-size:.65rem}
.tbl th:first-child,.tbl td:first-child{text-align:left}
.tbl tr.sr{background:rgba(251,191,36,.08)}.tbl tr.sr td{color:#b7791f}
.tbl tr.pr{background:rgba(56,178,172,.08)}.tbl tr.pr td{color:var(--accent-dark)}
.tbl tr.xtr{background:var(--accent-subtle);font-weight:600}.tbl tr.xtr td{color:var(--accent);border-top:2px solid var(--accent-border)}
.tbl tr.lr{background:rgba(239,68,68,.08)}.tbl tr.lr td{color:#ef4444}
.tc2{display:flex;flex-direction:column;gap:12px}
@media(min-width:520px){.tc2{flex-direction:row}.tc2>.co{flex:1}}
.co{background:var(--surface-2);border:1px solid var(--border);border-radius:10px;padding:12px}
.cot{font-size:.82rem;font-weight:600;color:var(--label);margin-bottom:10px;text-align:center;padding-bottom:6px;border-bottom:1px solid var(--border)}
.rg{display:flex;flex-direction:column;gap:5px}
.ro{display:flex;align-items:center;gap:6px;cursor:pointer}
.ro input{width:15px;height:15px;accent-color:var(--accent)}.ro span{font-size:.8rem;color:var(--text-primary)}
.cg{display:flex;flex-wrap:wrap;gap:8px;margin-top:6px}
.co2{display:flex;align-items:center;gap:5px;background:var(--surface-2);padding:6px 10px;border-radius:5px}
.co2 input{width:14px;height:14px;accent-color:var(--accent)}.co2 span{font-size:.75rem;color:var(--text-primary)}
.rbx{background:linear-gradient(135deg,var(--accent-subtle),var(--result-bg));border:2px solid var(--accent-border);border-radius:12px;padding:16px;margin-top:14px;text-align:center}
.rbx .mnn{font-size:2rem;font-weight:800;color:var(--accent);margin-bottom:6px}
.rbx .st2{font-size:.9rem;color:var(--accent-dark)}
.rbx .det{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-top:12px}
@media(min-width:500px){.rbx .det{grid-template-columns:repeat(4,1fr)}}
.rbx .di{background:var(--surface-2);padding:8px;border-radius:6px}
.rbx .di .dn{font-size:1.1rem;font-weight:700;color:var(--text-primary)}
.rbx .di .dt{font-size:.65rem;color:var(--text-secondary);margin-top:2px}
.mb{display:flex;gap:6px;margin-bottom:12px}
.mbt{flex:1;padding:10px;border-radius:8px;border:1px solid var(--border);background:var(--surface-2);color:var(--text-secondary);font-size:.8rem;cursor:pointer;text-align:center}
.mbt.active{background:var(--accent-subtle);border-color:var(--accent-border);color:var(--accent)}
.exb{background:var(--surface-2);border:1px solid var(--border);border-radius:10px;padding:12px;margin-top:12px;font-size:.78rem;line-height:1.6;color:var(--text-secondary)}.exb strong{color:var(--text-primary)}
.lb{background:rgba(251,191,36,.08);border:1px solid rgba(251,191,36,.2);border-radius:8px;padding:10px;margin-top:10px;font-size:.78rem;color:#b7791f}
.footer{text-align:center;margin-top:20px;padding:12px;color:var(--text-muted);font-size:.65rem;border-top:1px solid var(--border)}.footer a{color:var(--text-secondary)}
/* ── Currency dropdown ── */
.cur-wrap{position:relative;width:100%}
.cur-btn{width:100%;padding:11px 14px;border-radius:10px;border:1px solid var(--input-border);background:var(--input-bg);color:var(--text-primary);cursor:pointer;display:flex;align-items:center;justify-content:space-between;text-align:left;font-family:inherit;transition:border-color .15s}
.cur-btn:hover,.cur-btn:focus{outline:none;border-color:var(--accent)}
.cur-sel-code{font-size:1.15rem;font-weight:700;color:var(--accent);display:block;line-height:1.2}
.cur-sel-nm{font-size:.72rem;color:var(--text-secondary);display:block;margin-top:2px}
.cur-arr{font-size:12px;color:var(--text-muted);transition:transform .15s;flex-shrink:0;margin-left:8px}
.cur-arr.open{transform:rotate(180deg)}
.cur-dd{position:absolute;top:calc(100% + 4px);left:0;right:0;background:var(--surface);border:1px solid var(--border-2);border-radius:10px;box-shadow:0 6px 24px rgba(0,0,0,.14);z-index:200;max-height:260px;overflow-y:auto}
.cur-opt{display:flex;align-items:center;gap:10px;padding:9px 14px;cursor:pointer;border-bottom:1px solid var(--border)}
.cur-opt:last-child{border-bottom:none}
.cur-opt:hover{background:var(--accent-subtle)}
.cur-opt.sel{background:var(--accent-subtle)}
.cur-opt-code{font-size:.88rem;font-weight:700;color:var(--accent);min-width:38px}
.cur-opt-nm{font-size:.76rem;color:var(--text-secondary)}
/* Error modal */
.err-overlay{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(15,23,42,.55);z-index:1100;align-items:flex-start;justify-content:center;padding-top:16vh;animation:errFIn .2s}
@keyframes errFIn{from{opacity:0}to{opacity:1}}
@keyframes errSIn{from{transform:translateY(-20px) scale(.96);opacity:0}to{transform:translateY(0) scale(1);opacity:1}}
.err-box{background:var(--surface);border-radius:16px;padding:28px 24px;width:90%;max-width:360px;border:2px solid #ef4444;text-align:center;box-shadow:0 8px 40px rgba(239,68,68,.18);animation:errSIn .25s}
.err-icon{width:52px;height:52px;background:rgba(239,68,68,.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;font-size:24px}
.err-msg{font-size:14px;font-weight:500;color:var(--text-primary);margin-bottom:22px;line-height:1.6}
.err-ok{padding:10px 36px;border-radius:8px;border:none;background:linear-gradient(135deg,#ef4444,#dc2626);color:#fff;font-size:13px;font-weight:600;cursor:pointer;transition:transform .1s}
.err-ok:hover{transform:scale(1.03)}
.field-err{outline:2px solid #ef4444!important;outline-offset:2px;animation:fPulse .6s ease 2}
@keyframes fPulse{0%,100%{outline-color:#ef4444}50%{outline-color:#fca5a5}}
/* ── UX: Date clear (✕) button ── */
.date-wrap{position:relative;display:inline-block;width:100%}
.date-clear{position:absolute;right:8px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:13px;padding:2px 5px;display:none;z-index:2;line-height:1;border-radius:3px;font-family:inherit}
.date-wrap:hover .date-clear,.date-wrap .date-clear:focus{display:block}
.date-clear:hover{color:var(--text-secondary);background:var(--surface-2)}
@media(hover:none){.date-clear{display:block}}
/* ── UX: Clear item button ── */
.bclear{background:var(--surface-2);border:1px solid var(--border);color:var(--text-muted);padding:5px 10px;border-radius:5px;cursor:pointer;font-size:.72rem;margin-top:5px;margin-right:4px;font-family:inherit}
.bclear:hover{color:var(--text-secondary);border-color:var(--border-2)}
</style>
</head>
<body>
	<header style="background:#1a365d;position:sticky;top:0;z-index:200">
	<div style="max-width:900px;margin:0 auto;height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 14px">
	<a href="https://myavvo.md" target="_blank" style="display:flex;align-items:center;text-decoration:none;flex-shrink:0"><img src="logo.png" alt="myAVVO — Hub Juridic Moldova" width="0" height="0" style="position:absolute;opacity:0"><span style="font-family:'Roboto',sans-serif;font-weight:700;font-size:22px;letter-spacing:-.3px;line-height:1"><span style="color:#38b2ac">my</span><span style="color:#ffffff">AVVO</span></span></a>
	<h1 style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0">Calculator Juridic Moldova — Dobanda, Penalitate, Taxa de Stat | myAVVO</h1>
	<div style="display:flex;align-items:center;gap:8px">
	<button id="themeToggle" onclick="toggleTheme()" style="width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.8);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0"><span id="themeIcon">☾</span></button>

	</div>
	</div>
	<div style="background:#1a365d;padding:0 14px 10px">
	<div style="max-width:900px;margin:0 auto">
	<div class="tabs" style="width:100%">
	<div class="tab active" onclick="ST('dobanda')">Dobândă</div>
	<div class="tab" onclick="ST('pen')">Penalitate</div>
	<div class="tab" onclick="ST('taxa')">Taxă de Stat</div>
	<div class="tab" onclick="ST('zile')">Zile</div>
	</div>
	</div>
	</div>
	</header>
	<div class="mn" style="padding-bottom:32px">

	<div class="tc active" id="tab-dobanda">
	<div class="rb2"><div class="rt2"><strong>BNM:</strong> <span id="rc">0</span> | <span id="rf">-</span>-<span id="rto">-</span></div><button class="bf" onclick="AR()">Actualizează</button><div class="rs2" id="rS"></div></div>
	<div class="sb" id="sB"></div>
	<div id="dI">
	<div class="card"><div class="ct"><span class="stp">1</span><span>Valuta calculului</span></div><div class="cur-wrap" id="curWrap-dob"><button type="button" class="cur-btn" onclick="toggleCurDD('dob')"><div><span class="cur-sel-code" id="curCode-dob">MDL</span><span class="cur-sel-nm" id="curNm-dob">Leu moldovenesc</span></div><span class="cur-arr" id="curArr-dob">▾</span></button><div class="cur-dd" id="curDD-dob" style="display:none"></div></div></div>
	<div class="card"><div class="ct"><span class="stp">2</span><span>Procent (art.874 CC)</span></div><div class="rc"><div class="ri"><input type="radio" name="pY" id="p9" value="9" checked><label for="p9"><span class="big">+9%</span><span class="sm">Non-Consumatori</span></label></div><div class="ri"><input type="radio" name="pY" id="p5" value="5"><label for="p5"><span class="big">+5%</span><span class="sm">Consumatori</span></label></div></div></div>
	<div class="card"><div class="ct"><span class="stp">3</span>Sume scadente</div><div id="fL"></div><button class="ba" onclick="aF()">+ Adaugă</button></div>
	<div class="card"><div class="ct"><span class="stp">4</span>Plăți</div><div id="pL"></div><button class="ba" onclick="aP()">+ Adaugă</button></div>
	<div class="card"><div class="ct"><span class="stp">5</span>Data calcul</div><div class="fg"><label>Până la:</label><input type="text" id="dC" class="date-input" placeholder="zz/ll/aaaa" inputmode="numeric" maxlength="10" aria-label="Data calcul dobândă"></div></div>
	<div class="card"><div class="ct"><span class="stp">6</span>Opțiuni calcul</div>
	<div style="margin-bottom:10px"><div style="font-size:.75rem;color:#93c5fd;margin-bottom:6px">Ziua scadenței:</div><div class="rc"><div class="ri"><input type="radio" name="incS" id="incSN" value="0" checked><label for="incSN"><span class="big">Fără</span><span class="sm">Din ziua următoare</span></label></div><div class="ri"><input type="radio" name="incS" id="incSY" value="1"><label for="incSY"><span class="big">Include</span><span class="sm">Din ziua scadenței</span></label></div></div></div>
	<div><div style="font-size:.75rem;color:#93c5fd;margin-bottom:6px">Mod afișare:</div><div class="rc"><div class="ri"><input type="radio" name="modD" id="modDG" value="0" checked><label for="modDG"><span class="big">Grupat</span><span class="sm">Pe perioade</span></label></div><div class="ri"><input type="radio" name="modD" id="modDZ" value="1"><label for="modDZ"><span class="big">Detaliat</span><span class="sm">Zi cu zi</span></label></div></div></div>
	</div>
	<button class="bc" onclick="cD()">Calculează Dobânda</button>
	</div>
	<div class="rse" id="dR">
	<div class="card rca"><div class="rh"><div class="rl">Dobânda legală</div><div class="rv" id="dT">0</div><div class="rsu" id="dP"></div></div><div class="rsum"><div class="si"><div class="sl">Sume</div><div class="sv" id="d1">-</div></div><div class="si"><div class="sl">Achitat</div><div class="sv" id="d2">-</div></div><div class="si"><div class="sl">Zile</div><div class="sv" id="d3">-</div></div><div class="si"><div class="sl">%</div><div class="sv" id="d4">-</div></div></div></div>
	<div class="card"><div class="th"><span class="tt2">Detalii</span></div><div class="tw"><table class="tbl"><thead><tr><th>Perioadă</th><th>Zile</th><th>Suma</th><th>BNM</th><th>Tot%</th><th>Dob</th><th>Cum</th><th>Obs</th></tr></thead><tbody id="dTB"></tbody></table></div></div>
