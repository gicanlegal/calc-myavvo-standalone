	var baseY=doc.lastAutoTable.finalY+6;var notaTax=document.getElementById('tEx')?document.getElementById('tEx').innerHTML:'';if(notaTax){var notaText=noDiac(notaTax.replace(/<br\s*\/?>\s*/gi,'\n').replace(/<li>/gi,'\u2022 ').replace(/<\/li>/gi,'\n').replace(/<[^>]+>/g,'').replace(/&amp;/g,'&').replace(/&lt;/g,'<').replace(/&gt;/g,'>').trim());if(notaText){var notaLines=doc.splitTextToSize(notaText,UW-8);var notaH=notaLines.length*5+14;doc.setFillColor(235,248,255);doc.setDrawColor(tl[0],tl[1],tl[2]);doc.setLineWidth(0.5);doc.roundedRect(ML,baseY,UW,notaH,3,3,'FD');doc.setFont('helvetica','bold');doc.setFontSize(8);doc.setTextColor(tl[0],tl[1],tl[2]);doc.text('Nota de calcul',ML+5,baseY+8);doc.setFont('helvetica','normal');doc.setFontSize(8);doc.setTextColor(dg[0],dg[1],dg[2]);notaLines.forEach(function(line,i){doc.text(line,ML+5,baseY+14+i*5);});baseY+=notaH+4;}}var fy=baseY;doc.setLineWidth(1.5);doc.setDrawColor(nv[0],nv[1],nv[2]);doc.line(ML,fy,ML+UW/2,fy);doc.setDrawColor(tl[0],tl[1],tl[2]);doc.line(ML+UW/2,fy,MR,fy);
	_pdfFtr(doc,dt.str);doc.save('myavvo-taxa-stat-'+dt.file+'.pdf');});}

